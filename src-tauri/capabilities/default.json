{
  "$schema": "https://raw.githubusercontent.com/nicegui-dev/nicegui/main/nicegui/static/.well-known/capabilities.schema.json",
  "identifier": "default",
  "description": "Default capabilities for Notes app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:default",
    "fs:allow-read",
    "fs:allow-write",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-read-dir",
    "shell:allow-open",
    "shell:allow-spawn",
    "shell:allow-stdin-write",
    "notification:default",
    "sql:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-ask",
    "updater:default",
    "process:allow-restart"
  ]
}
