#!/usr/bin/env bash
# Block push when any file modified between the upstream branch and
# HEAD is below 80% line coverage. See docs-llm/v1/definition-of-done.md.
set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"

# Resolve the upstream branch we're pushing against.
UPSTREAM="$(git rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || true)"
BASE_REF="${UPSTREAM:-origin/main}"

export BASE_REF
exec "$REPO_ROOT/scripts/coverage-check.sh"
